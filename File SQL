-- Bạn mở SSMS, tạo một database tên PriSchool rồi chạy toàn bộ đoạn script dưới đây:
 CREATE DATABASE PriSchool;
 GO
 USE PriSchool;
 GO

-- 1. Bảng TaiKhoan (Chỉ cho phép 'GiaoVien' và 'CanBo')
CREATE TABLE TaiKhoan (
    TaiKhoanID INT IDENTITY(1,1) PRIMARY KEY,
    TenDangNhap VARCHAR(35) NOT NULL UNIQUE,
    MatKhau VARCHAR(255) NOT NULL, -- Lưu text thô trực tiếp
    VaiTro VARCHAR(20) NOT NULL CHECK (VaiTro IN ('GiaoVien', 'CanBo')),
    IsActive BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE(),
    NgayCapNhat DATETIME DEFAULT GETDATE()
);

-- 2. Bảng CanBo (Đóng vai trò Admin cấp cao điều hành trường)
CREATE TABLE CanBo (
    CanBoID INT IDENTITY(1,1) PRIMARY KEY,
    TaiKhoanID INT NULL FOREIGN KEY REFERENCES TaiKhoan(TaiKhoanID) ON DELETE SET NULL,
    HoTen NVARCHAR(100) NOT NULL,
    NgaySinh DATE NULL,
    SoDienThoai VARCHAR(20) NULL,
    ChucVu NVARCHAR(100) NULL,
    IsActive BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE(),
    NgayCapNhat DATETIME DEFAULT GETDATE()
);

-- 3. Bảng GiaoVien
CREATE TABLE GiaoVien (
    GiaoVienID INT IDENTITY(1,1) PRIMARY KEY,
    TaiKhoanID INT NULL FOREIGN KEY REFERENCES TaiKhoan(TaiKhoanID) ON DELETE SET NULL,
    HoTen NVARCHAR(100) NOT NULL,
    NgaySinh DATE NULL,
    SoDienThoai VARCHAR(20) NULL,
    DiaChi NVARCHAR(200) NULL,
    AnhDaiDien VARCHAR(255) NULL,
    IsActive BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE(),
    NgayCapNhat DATETIME DEFAULT GETDATE()
);

-- 4. Bảng HocSinh
CREATE TABLE HocSinh (
    HocSinhID INT IDENTITY(1,1) PRIMARY KEY,
    TenHocSinh NVARCHAR(100) NOT NULL,
    NgaySinh DATE NOT NULL,
    GioiTinh NVARCHAR(10) NOT NULL CHECK (GioiTinh IN (N'Nam', N'Nữ')),
    DiaChi NVARCHAR(200) NULL,
    AnhDaiDien VARCHAR(255) NULL,
    IsActive BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE()
);

-- 5. Bảng Khoi
CREATE TABLE Khoi (
    KhoiID INT IDENTITY(1,1) PRIMARY KEY,
    TenKhoi NVARCHAR(45) NOT NULL
);

-- 6. Bảng ThoiGian (Năm học & Học kỳ)
CREATE TABLE ThoiGian (
    ThoiGianID INT IDENTITY(1,1) PRIMARY KEY,
    TenNam VARCHAR(20) NOT NULL,
    TenKy NVARCHAR(20) NOT NULL,
    IsCurrent BIT DEFAULT 0,
    NgayBatDau DATE NULL,
    NgayKetThuc DATE NULL
);

-- 7. Bảng Lop
CREATE TABLE Lop (
    LopID INT IDENTITY(1,1) PRIMARY KEY,
    KhoiID INT NOT NULL FOREIGN KEY REFERENCES Khoi(KhoiID),
    TenLop VARCHAR(10) NOT NULL,
    ThoiGianID INT NOT NULL FOREIGN KEY REFERENCES ThoiGian(ThoiGianID),
    GiaoVienID INT NULL FOREIGN KEY REFERENCES GiaoVien(GiaoVienID) ON DELETE SET NULL,
    NgayTao DATETIME DEFAULT GETDATE()
);

-- 8. Bảng MonHoc
CREATE TABLE MonHoc (
    MonHocID INT IDENTITY(1,1) PRIMARY KEY,
    TenMonHoc NVARCHAR(100) NOT NULL,
    SoTiet TINYINT NOT NULL,
    MoTa NVARCHAR(200) NULL,
    IsActive BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE(),
    NgayCapNhat DATETIME DEFAULT GETDATE()
);

-- 9. Bảng MonHoc_Khoi
CREATE TABLE MonHoc_Khoi (
    MonHocID INT NOT NULL FOREIGN KEY REFERENCES MonHoc(MonHocID) ON DELETE CASCADE,
    KhoiID INT NOT NULL FOREIGN KEY REFERENCES Khoi(KhoiID) ON DELETE CASCADE,
    PRIMARY KEY (MonHocID, KhoiID)
);

-- 10. Bảng DiemThi
CREATE TABLE DiemThi (
    DiemThiID INT IDENTITY(1,1) PRIMARY KEY,
    HocSinhID INT NOT NULL FOREIGN KEY REFERENCES HocSinh(HocSinhID) ON DELETE CASCADE,
    ThoiGianID INT NOT NULL FOREIGN KEY REFERENCES ThoiGian(ThoiGianID),
    MonHocID INT NOT NULL FOREIGN KEY REFERENCES MonHoc(MonHocID),
    DiemMieng DECIMAL(4,2) NULL,
    DiemGiuaKy DECIMAL(4,2) NULL,
    DiemCuoiKy DECIMAL(4,2) NULL,
    NgayCapNhat DATETIME DEFAULT GETDATE()
);

-- 11. Bảng HocBa
CREATE TABLE HocBa (
    HocBaID INT IDENTITY(1,1) PRIMARY KEY,
    HocSinhID INT NOT NULL FOREIGN KEY REFERENCES HocSinh(HocSinhID) ON DELETE CASCADE,
    LopID INT NOT NULL FOREIGN KEY REFERENCES Lop(LopID),
    NhanXet NVARCHAR(MAX) NULL,
    DoLenLop BIT DEFAULT 1,
    NgayTao DATETIME DEFAULT GETDATE()
);

-- 12. Bảng Thu
CREATE TABLE Thu (
    ThuID INT IDENTITY(1,1) PRIMARY KEY,
    TenThu NVARCHAR(10) NOT NULL,
    ThuTu TINYINT NOT NULL
);

-- 13. Bảng TietHoc
CREATE TABLE TietHoc (
    TietHocID INT IDENTITY(1,1) PRIMARY KEY,
    TenTiet NVARCHAR(20) NOT NULL,
    TietSo TINYINT NOT NULL
);

-- 14. Bảng ThoiKhoaBieu
CREATE TABLE ThoiKhoaBieu (
    ThoiKhoaBieuID INT IDENTITY(1,1) PRIMARY KEY,
    LopID INT NOT NULL FOREIGN KEY REFERENCES Lop(LopID) ON DELETE CASCADE,
    ThuID INT NOT NULL FOREIGN KEY REFERENCES Thu(ThuID),
    TietHocID INT NOT NULL FOREIGN KEY REFERENCES TietHoc(TietHocID),
    MonHocID INT NOT NULL FOREIGN KEY REFERENCES MonHoc(MonHocID),
    GiaoVienID INT NULL FOREIGN KEY REFERENCES GiaoVien(GiaoVienID),
    GhiChu NVARCHAR(200) NULL
);
GO

